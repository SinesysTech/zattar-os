{
  "id": "contratacao-aplicativos",
  "version": "1.0.0",
  "sections": [
    {
      "id": "etapa-1-busca-cliente",
      "title": "Etapa 1: Busca de Cliente",
      "description": "Busque o cliente por CPF para preencher automaticamente os dados",
      "icon": "idcard",
      "preferredField": "busca_cliente",
      "fields": [
        {
          "id": "busca_cliente",
          "name": "busca_cliente",
          "label": "Buscar Cliente por CPF",
          "type": "client_search",
          "placeholder": "Digite o CPF do cliente",
          "gridColumns": 3,
          "helpText": "Digite o CPF do cliente e clique em buscar. Se encontrado, os dados serão preenchidos automaticamente.",
          "entitySearch": {
            "entityType": "cliente",
            "searchBy": ["cpf"],
            "autoFill": {
              "nome": "cliente_nome",
              "cpf": "cliente_cpf",
              "emails[0]": "cliente_email",
              "ddd_celular": "cliente_ddd_celular",
              "numero_celular": "cliente_numero_celular",
              "data_nascimento": "cliente_data_nascimento",
              "rg": "cliente_rg",
              "estado_civil": "cliente_estado_civil",
              "nome_genitora": "cliente_nome_genitora"
            }
          }
        }
      ]
    },
    {
      "id": "etapa-2-dados-cliente",
      "title": "Etapa 2: Dados do Cliente",
      "description": "Dados pessoais do cliente",
      "icon": "user",
      "fields": [
        {
          "id": "cliente_nome",
          "name": "cliente_nome",
          "label": "Nome Completo",
          "type": "text",
          "placeholder": "Nome completo do cliente",
          "gridColumns": 3,
          "validation": {
            "required": true
          }
        },
        {
          "id": "cliente_cpf",
          "name": "cliente_cpf",
          "label": "CPF",
          "type": "cpf",
          "placeholder": "000.000.000-00",
          "gridColumns": 1,
          "validation": {
            "required": true
          }
        },
        {
          "id": "cliente_email",
          "name": "cliente_email",
          "label": "E-mail",
          "type": "email",
          "placeholder": "email@exemplo.com",
          "gridColumns": 2,
          "validation": {
            "required": true
          }
        },
        {
          "id": "cliente_ddd_celular",
          "name": "cliente_ddd_celular",
          "label": "DDD Celular",
          "type": "text",
          "placeholder": "11",
          "gridColumns": 1,
          "validation": {
            "required": false
          }
        },
        {
          "id": "cliente_numero_celular",
          "name": "cliente_numero_celular",
          "label": "Número Celular",
          "type": "phone",
          "placeholder": "(00) 00000-0000",
          "gridColumns": 2,
          "validation": {
            "required": false
          }
        },
        {
          "id": "cliente_data_nascimento",
          "name": "cliente_data_nascimento",
          "label": "Data de Nascimento",
          "type": "date",
          "gridColumns": 1,
          "validation": {
            "required": false
          }
        },
        {
          "id": "cliente_rg",
          "name": "cliente_rg",
          "label": "RG",
          "type": "text",
          "placeholder": "RG do cliente",
          "gridColumns": 1,
          "validation": {
            "required": false
          }
        },
        {
          "id": "cliente_estado_civil",
          "name": "cliente_estado_civil",
          "label": "Estado Civil",
          "type": "select",
          "gridColumns": 1,
          "options": [
            { "label": "Solteiro(a)", "value": "solteiro" },
            { "label": "Casado(a)", "value": "casado" },
            { "label": "Divorciado(a)", "value": "divorciado" },
            { "label": "Viúvo(a)", "value": "viuvo" },
            { "label": "União Estável", "value": "uniao_estavel" }
          ],
          "validation": {
            "required": false
          }
        },
        {
          "id": "cliente_nome_genitora",
          "name": "cliente_nome_genitora",
          "label": "Nome da Genitora",
          "type": "text",
          "placeholder": "Nome da mãe",
          "gridColumns": 2,
          "validation": {
            "required": false
          }
        }
      ]
    },
    {
      "id": "section-parte-contraria",
      "title": "Parte Contrária",
      "fields": [
        {
          "id": "field-pc-cnpj",
          "name": "pc_cnpj",
          "type": "cnpj",
          "label": "CNPJ",
          "placeholder": "00.000.000/0000-00",
          "helpText": "Em breve o CNPJ vai preencher automaticamente os dados da empresa.",
          "gridColumns": 1,
          "conditional": { "field": "field-pc-tipo-pessoa", "value": "pj", "operator": "=" },
          "validation": { "required": true, "message": "CNPJ é obrigatório para Pessoa Jurídica" },
          "entitySearch": {
            "entityType": "parte_contraria",
            "searchBy": ["cnpj"],
            "autoFill": {
              "cpf": "field-pc-cpf",
              "cnpj": "field-pc-cnpj",
              "nome": "field-pc-nome",
              "tipo_pessoa": "field-pc-tipo-pessoa",
              "endereco.cep": "field-pc-cep",
              "numero_celular": "field-pc-telefone",
              "endereco.bairro": "field-pc-bairro",
              "endereco.numero": "field-pc-numero",
              "endereco.municipio": "field-pc-municipio",
              "endereco.logradouro": "field-pc-logradouro",
              "endereco.complemento": "field-pc-complemento",
              "endereco.estado_sigla": "field-pc-estado",
              "emails[0]": "field-pc-email"
            }
          }
        },
        {
          "id": "field-pc-tipo-pessoa",
          "name": "pc_tipo_pessoa",
          "type": "radio",
          "label": "Tipo",
          "gridColumns": 1,
          "defaultValue": "pj",
          "options": [
            { "label": "Pessoa Jurídica", "value": "pj" },
            { "label": "Pessoa Física", "value": "pf" }
          ],
          "validation": { "required": true, "message": "Selecione o tipo de pessoa" }
        },
        {
          "id": "field-pc-cpf",
          "name": "pc_cpf",
          "type": "cpf",
          "label": "CPF",
          "placeholder": "000.000.000-00",
          "gridColumns": 1,
          "conditional": { "field": "field-pc-tipo-pessoa", "value": "pf", "operator": "=" },
          "validation": { "required": true, "message": "CPF é obrigatório para Pessoa Física" }
        },
        {
          "id": "field-pc-nome",
          "name": "pc_nome",
          "type": "text",
          "label": "Razão Social / Nome",
          "placeholder": "Razão social ou nome completo",
          "gridColumns": 1,
          "validation": { "required": true, "min": 3, "max": 200, "message": "Nome ou Razão Social é obrigatório" }
        },
        {
          "id": "field-pc-telefone",
          "name": "pc_telefone",
          "type": "phone",
          "label": "Telefone",
          "placeholder": "(00) 00000-0000",
          "gridColumns": 4
        },
        {
          "id": "field-pc-email",
          "name": "pc_email",
          "type": "email",
          "label": "E-mail (opcional)",
          "placeholder": "email@exemplo.com",
          "gridColumns": 4
        },
        {
          "id": "field-pc-cep",
          "name": "pc_endereco_cep",
          "type": "cep",
          "label": "CEP",
          "placeholder": "00000-000",
          "helpText": "O endereço será preenchido automaticamente.",
          "gridColumns": 1
        },
        {
          "id": "field-pc-logradouro",
          "name": "pc_endereco_logradouro",
          "type": "text",
          "label": "Logradouro",
          "placeholder": "Rua, Avenida, etc.",
          "gridColumns": 2
        },
        {
          "id": "field-pc-numero",
          "name": "pc_endereco_numero",
          "type": "text",
          "label": "Número",
          "placeholder": "Nº",
          "gridColumns": 3
        },
        {
          "id": "field-pc-complemento",
          "name": "pc_endereco_complemento",
          "type": "text",
          "label": "Complemento (opcional)",
          "placeholder": "Apto, Bloco, Sala",
          "gridColumns": 4
        },
        {
          "id": "field-pc-bairro",
          "name": "pc_endereco_bairro",
          "type": "text",
          "label": "Bairro",
          "placeholder": "Bairro",
          "gridColumns": 4
        },
        {
          "id": "field-pc-municipio",
          "name": "pc_endereco_municipio",
          "type": "text",
          "label": "Cidade",
          "placeholder": "Cidade",
          "gridColumns": 4
        },
        {
          "id": "field-pc-estado",
          "name": "pc_endereco_estado",
          "type": "select",
          "label": "Estado",
          "gridColumns": 4,
          "options": [
            { "label": "Acre", "value": "AC" },
            { "label": "Alagoas", "value": "AL" },
            { "label": "Amapá", "value": "AP" },
            { "label": "Amazonas", "value": "AM" },
            { "label": "Bahia", "value": "BA" },
            { "label": "Ceará", "value": "CE" },
            { "label": "Distrito Federal", "value": "DF" },
            { "label": "Espírito Santo", "value": "ES" },
            { "label": "Goiás", "value": "GO" },
            { "label": "Maranhão", "value": "MA" },
            { "label": "Mato Grosso", "value": "MT" },
            { "label": "Mato Grosso do Sul", "value": "MS" },
            { "label": "Minas Gerais", "value": "MG" },
            { "label": "Pará", "value": "PA" },
            { "label": "Paraíba", "value": "PB" },
            { "label": "Paraná", "value": "PR" },
            { "label": "Pernambuco", "value": "PE" },
            { "label": "Piauí", "value": "PI" },
            { "label": "Rio de Janeiro", "value": "RJ" },
            { "label": "Rio Grande do Norte", "value": "RN" },
            { "label": "Rio Grande do Sul", "value": "RS" },
            { "label": "Rondônia", "value": "RO" },
            { "label": "Roraima", "value": "RR" },
            { "label": "Santa Catarina", "value": "SC" },
            { "label": "São Paulo", "value": "SP" },
            { "label": "Sergipe", "value": "SE" },
            { "label": "Tocantins", "value": "TO" }
          ]
        }
      ]
    },
    {
      "id": "etapa-4-dados-acao",
      "title": "Etapa 4: Dados da Ação Trabalhista",
      "description": "Informações sobre a ação trabalhista",
      "icon": "briefcase",
      "fields": [
        {
          "id": "data_inicio_trabalho",
          "name": "data_inicio_trabalho",
          "label": "Data de Início do Trabalho",
          "type": "date",
          "gridColumns": 1,
          "validation": {
            "required": true
          },
          "helpText": "Data em que o trabalhador iniciou suas atividades"
        },
        {
          "id": "trabalhando_atualmente",
          "name": "trabalhando_atualmente",
          "label": "Trabalhando Atualmente",
          "type": "checkbox",
          "gridColumns": 1,
          "defaultValue": false,
          "validation": {
            "required": false
          },
          "helpText": "Marque se o trabalhador ainda está trabalhando"
        },
        {
          "id": "data_termino",
          "name": "data_termino",
          "label": "Data de Término",
          "type": "date",
          "gridColumns": 1,
          "validation": {
            "required": false
          },
          "conditional": {
            "field": "trabalhando_atualmente",
            "operator": "=",
            "value": false
          },
          "helpText": "Data em que o trabalhador encerrou suas atividades (aparece apenas se não estiver trabalhando atualmente)"
        },
        {
          "id": "objeto_acao",
          "name": "objeto_acao",
          "label": "Objeto da Ação",
          "type": "textarea",
          "placeholder": "Descreva o objeto da ação trabalhista...",
          "gridColumns": 3,
          "validation": {
            "required": true,
            "min": 10
          },
          "helpText": "Descreva detalhadamente o objeto da ação trabalhista"
        },
        {
          "id": "tipo_contrato",
          "name": "tipo_contrato",
          "label": "Tipo de Contrato",
          "type": "text",
          "defaultValue": "ajuizamento",
          "hidden": true,
          "gridColumns": 1,
          "validation": {
            "required": true
          }
        }
      ]
    }
  ],
  "globalValidations": []
}
